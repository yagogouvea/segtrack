# 🔧 Configurações do Servidor
PORT=3001
NODE_ENV=development

# 🌐 URLs permitidas para CORS
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,https://segtrack.comerceoficial.com

# 🔒 Configurações de Autenticação JWT
JWT_SECRET=segtrack-ultra-seguro-123
JWT_EXPIRATION=24h

# 💾 Configurações do Banco de Dados (Google Cloud SQL - MySQL)
DATABASE_URL="mysql://segtrack_admin:3500817Y%40g@35.192.214.51:3306/segtrack"

# 📤 Upload de Arquivos
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880

# 📊 Rate Limiting
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=1000

# 📝 Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# 🔐 Segurança
BCRYPT_SALT_ROUNDS=10
ENABLE_HTTPS=false

# ⚡ Cache
REDIS_URL=redis://localhost:6379

# 📈 Monitoramento
ENABLE_METRICS=false
METRICS_PORT=9090

# 🌍 Base para geração de URLs (ex: links de fotos)
